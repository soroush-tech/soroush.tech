{
  "name": "@soroush/web",
  "description": "Masoud Soroush - Software Engineer",
  "private": true,
  "homepage": "https://soroush.tech",
  "author": {
    "name": "Masoud Soroush",
    "email": "masoud@soroush.tech"
  },
  "version": "0.1.0",
  "type": "module",
  "license": "Custom -> SEE LICENSE file",
  "scripts": {
    "dev": "vite",
    "setup": "node scripts/setup-env.mjs",
    "lint": "eslint ./ --ext .js,.jsx,.ts,.tsx --report-unused-disable-directives --cache --max-warnings 0",
    "git:refresh": "git update-index -q --refresh",
    "gen:experienceGraph": "node scripts/gen-experienceGraph.ts",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:silent": "vitest run --silent --no-watch",
    "test:unit": "vitest --project=unit",
    "test:storybook": "vitest --project=storybook",
    "test:browser": "vitest --project=unit-browser",
    "test:e2e": "playwright test",
    "test:e2e:firefox": "playwright test --project=firefox",
    "test:e2e:webkit": "playwright test --project=webkit",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:coverage": "vitest run --coverage",
    "test:coverage:e2e": "cross-env E2E_COVERAGE=true playwright test --project=chromium",
    "test:coverage:storybook": "vitest run --project=storybook --coverage",
    "test:coverage:unit": "vitest run --project=unit --coverage ",
    "test:coverage:browser": "vitest run --project=unit-browser --coverage",
    "test:coverage:ui": "vitest run --coverage --project=unit && open coverage/lcov-report/index.html",
    "coverage:check": "node scripts/coverage-check.ts",
    "storybook": "cross-env NODE_ENV=storybook storybook dev -p 6006",
    "prebuild": "tsc -b",
    "build": "vite build",
    "build:compress": "cross-env COMPRESS=true pnpm build",
    "build:storybook": "cross-env NODE_ENV=storybook storybook build",
    "preview": "vite preview",
    "preview:e2e": "serve build/client -l 9999",
    "preview:storybook": "npx serve storybook-static",
    "deploy": "gh-pages -d build"
  },
  "dependencies": {
    "@emotion/cache": "^11.14.0",
    "@emotion/css": "^11.13.5",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@soroush.tech/schema": "workspace:*",
    "@soroush.tech/styled-system": "workspace:*",
    "@tanstack/react-form": "^1.33.0",
    "@tanstack/react-query": "^5.101.1",
    "axios": "^1.18.1",
    "clsx": "^2.1.1",
    "d3": "^7.9.0",
    "query-string": "^9.4.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "vike": "^0.4.259",
    "vike-react": "^0.6.24",
    "vike-react-query": "^0.1.13",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.2.1",
    "@codecov/vite-plugin": "^2.0.1",
    "@emotion/babel-plugin": "^11.13.5",
    "@emotion/css-prettifier": "^1.2.0",
    "@emotion/jest": "^11.14.2",
    "@emotion/server": "^11.11.0",
    "@playwright/test": "^1.61.1",
    "@soroush.tech/eslint-config": "workspace:*",
    "@soroush.tech/playwright-coverage": "workspace:*",
    "@soroush.tech/vite-plugin-msw-server": "workspace:*",
    "@soroush.tech/vite-plugin-sitemap": "workspace:*",
    "@soroush.tech/vite-plugin-watch": "workspace:*",
    "@storybook/addon-a11y": "^10.4.6",
    "@storybook/addon-docs": "^10.4.6",
    "@storybook/addon-onboarding": "^10.4.6",
    "@storybook/addon-themes": "^10.4.6",
    "@storybook/addon-vitest": "^10.4.6",
    "@storybook/react-vite": "^10.4.6",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/d3": "^7.4.3",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.62.1",
    "@typescript-eslint/parser": "^8.62.1",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/browser": "4.1.9",
    "@vitest/browser-playwright": "^4.1.9",
    "@vitest/coverage-v8": "^4.1.9",
    "@vitest/ui": "^4.1.9",
    "chromatic": "^17.8.0",
    "cross-env": "^10.1.0",
    "eslint": "^10.6.0",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "eslint-plugin-storybook": "^10.4.6",
    "gh-pages": "^6.3.0",
    "globals": "^17.7.0",
    "jest-environment-jsdom": "^30.4.1",
    "jsdom": "^29.1.1",
    "monocart-coverage-reports": "^2.12.12",
    "msw": "^2.14.6",
    "msw-storybook-addon": "^2.0.7",
    "prettier": "^3.9.4",
    "serve": "^14.2.6",
    "storybook": "^10.4.6",
    "ts-node": "^10.9.2",
    "typescript": "~6.0.3",
    "vite": "~8.0.16",
    "vite-imagetools": "^10.0.1",
    "vite-plugin-compression2": "^2.5.3",
    "vite-plugin-svgr": "^5.2.0",
    "vitest": "^4.1.9"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}

{
  "name": "@soroush.tech/styled-system",
  "version": "5.2.0",
  "description": "Maintained, first-class-TypeScript rewrite of styled-system — responsive, theme-aware style props for CSS-in-JS. Drop-in replacement for styled-system v5.",
  "keywords": [
    "styled-system",
    "css-in-js",
    "emotion",
    "theme",
    "responsive",
    "design-system",
    "typescript"
  ],
  "author": "Masoud Soroush <masoud@soroush.tech>",
  "license": "MIT",
  "homepage": "https://github.com/soroush-tech/soroush.tech/tree/main/packages/styled-system#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/soroush-tech/soroush.tech.git",
    "directory": "packages/styled-system"
  },
  "bugs": {
    "url": "https://github.com/soroush-tech/soroush.tech/issues"
  },
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "exports": {
    ".": "./src/index.ts",
    "./core": "./src/core/index.ts",
    "./space": "./src/space/index.ts",
    "./color": "./src/color/index.ts",
    "./layout": "./src/layout/index.ts",
    "./typography": "./src/typography/index.ts",
    "./flexbox": "./src/flexbox/index.ts",

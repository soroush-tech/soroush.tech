        "import": {
          "types": "./dist/theme-get.d.mts",
          "default": "./dist/theme-get.mjs"
        },
        "require": {
          "types": "./dist/theme-get.d.cts",
          "default": "./dist/theme-get.cjs"
        }
      },
      "./props": {
        "import": {

{
  "name": "soroush.tech",
  "description": "Soroush.tech blog",
  "private": true,
  "homepage": "https://soroush.tech",
  "author": {
    "name": "Masoud Soroush",
    "email": "masoud@soroush.tech"
  },
  "version": "0.1.0",
  "type": "module",
  "license": "Custom -> SEE LICENSE file",
  "scripts": {
    "prepare": "husky",
    "dev": "vite",
    "lint": "eslint ./ --ext .js,.jsx,.ts,.tsx --report-unused-disable-directives --cache --max-warnings 0",
    "format": "prettier --write .",
    "git:refresh": "git update-index -q --refresh",
    "test": "vitest",
    "test:unit": "vitest --project=unit",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:storybook": "vitest --project=storybook",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:silent": "vitest run --silent --no-watch",
    "test:coverage": "vitest run --coverage",
    "test:coverage:storybook": "vitest run --project=storybook --coverage",
    "test:coverage:unit": "vitest run --project=unit --coverage ",
    "test:coverage:ui": "vitest run --coverage --project=unit && open coverage/lcov-report/index.html",
    "storybook": "cross-env NODE_ENV=storybook storybook dev -p 6006",
    "build": "tsc -b && vite build",
    "build:storybook": "cross-env NODE_ENV=storybook storybook build",
    "preview": "vite preview",
    "preview:storybook": "npx serve storybook-static",
    "deploy": "gh-pages -d build"
  },
  "dependencies": {
    "@emotion/cache": "^11.14.0",
    "@emotion/css": "^11.13.5",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@styled-system/should-forward-prop": "^5.1.5",
    "@tanstack/react-query": "^5.100.14",
    "axios": "^1.16.1",
    "clsx": "^2.1.1",
    "d3": "^7.9.0",
    "query-string": "^9.4.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "styled-system": "^5.1.5",
    "vike": "^0.4.259",
    "vike-react": "^0.6.23",
    "vike-react-query": "^0.1.12"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.2.1",
    "@emotion/babel-plugin": "^11.13.5",
    "@emotion/css-prettifier": "^1.2.0",
    "@emotion/jest": "^11.14.2",
    "@emotion/server": "^11.11.0",
    "@eslint/js": "^10.0.0",
    "@playwright/test": "^1.60.0",
    "@storybook/addon-a11y": "^10.4.1",
    "@storybook/addon-docs": "^10.4.1",
    "@storybook/addon-onboarding": "^10.4.1",
    "@storybook/addon-themes": "^10.4.1",
    "@storybook/addon-vitest": "^10.4.1",
    "@storybook/react-vite": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/d3": "^7.4.3",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.12.4",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@types/styled-system": "^5.1.25",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.60.0",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/browser": "4.1.7",
    "@vitest/browser-playwright": "^4.1.7",
    "@vitest/coverage-v8": "^4.1.7",
    "@vitest/ui": "^4.1.7",
    "chromatic": "^17.1.0",
    "cross-env": "^10.1.0",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-storybook": "^10.4.1",
    "gh-pages": "^6.3.0",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "jest-environment-jsdom": "^30.4.1",
    "jsdom": "^29.1.1",
    "msw": "^2.14.6",
    "msw-storybook-addon": "^2.0.7",
    "prettier": "^3.8.3",
    "pretty-quick": "^4.2.2",
    "storybook": "^10.4.1",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.60.0",
    "vite": "^8.0.14",
    "vite-plugin-svgr": "^5.2.0",
    "vitest": "^4.1.7"
  },
  "packageManager": "pnpm@10.13.1",
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}

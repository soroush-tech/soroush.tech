{
  "name": "soroush.tech",
  "description": "Masoud Soroush - Software Engineer",
  "private": true,
  "type": "module",
  "license": "Custom -> SEE LICENSE file",
  "author": {
    "name": "Masoud Soroush",
    "email": "masoud@soroush.tech"
  },
  "scripts": {
    "prepare": "husky",
    "postprepare": "pnpm -r run setup",
    "setup": "pnpm -r run setup",
    "format": "prettier --write .",
    "gen:publish-options": "node scripts/gen-publish-options.mjs",
    "dev": "pnpm --parallel -r dev",
    "dev:web": "pnpm --filter @soroush/web dev",
    "dev:api": "pnpm --filter @soroush/api dev",
    "build": "pnpm --filter @soroush/web build",
    "build:compress": "pnpm --filter @soroush/web build:compress",
    "build:storybook": "pnpm --filter @soroush/web build:storybook",
    "preview": "pnpm --filter @soroush/web preview",
    "preview:e2e": "pnpm --filter @soroush/web preview:e2e",
    "storybook": "pnpm --filter @soroush/web storybook",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "prebuild": "pnpm --filter @soroush/web prebuild",
    "test": "pnpm -r test",
    "test:coverage": "pnpm -r test:coverage",
    "test:coverage:unit": "pnpm --filter @soroush/web test:coverage:unit",
    "test:coverage:browser": "pnpm --filter @soroush/web test:coverage:browser",
    "test:coverage:storybook": "pnpm --filter @soroush/web test:coverage:storybook",
    "test:coverage:e2e": "pnpm --filter @soroush/web test:coverage:e2e",
    "test:e2e": "pnpm --filter @soroush/web test:e2e",
    "test:e2e:firefox": "pnpm --filter @soroush/web test:e2e:firefox",
    "test:e2e:webkit": "pnpm --filter @soroush/web test:e2e:webkit",
    "coverage:check": "pnpm --filter @soroush/web coverage:check",
    "deploy": "pnpm --filter @soroush/web deploy"
  },
  "devDependencies": {
    "@emotion/css-prettifier": "^1.2.0",
    "husky": "^9.1.7",
    "prettier": "^3.9.4",
    "pretty-quick": "^4.2.2"
  },
  "packageManager": "pnpm@10.13.1"
}

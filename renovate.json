{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "dependencyDashboard": true,
  "rebaseWhen": "conflicted",
  "prHourlyLimit": 2,
  "labels": ["dependencies"],
  "semanticCommits": "enabled",
  "enabledManagers": ["npm"],
  "lockFileMaintenance": {
    "enabled": false
  },
  "packageRules": [
    {
      "matchDepTypes": ["packageManager"],
      "enabled": false
    },
    {
      "matchUpdateTypes": ["pin"],
      "enabled": false
    },
    {
      "matchUpdateTypes": ["minor"],
      "groupName": "minor updates",
      "automerge": false
    },
    {
      "matchPackageNames": ["/^react/", "/^@types\\/react/", "/^vike/"],
      "groupName": "React packages"
    },
    {
      "matchPackageNames": ["/^@emotion/", "/^styled-system/"],
      "groupName": "Style packages"
    },
    {
      "matchPackageNames": [
        "/^vitest/",
        "/^@vitest\\//",
        "/^@testing-library/",
        "/^@types\\/jest/",
        "/^jest/",
        "/^playwright/",
        "/^@playwright\\//",
        "/^jsdom/",
        "/^msw/"
      ],
      "groupName": "Testing stack"
    },
    {
      "matchPackageNames": ["/^storybook/", "/^@storybook\\//", "/^@chromatic-com\\//"],
      "groupName": "Storybook stack"
    },
    {
      "matchPackageNames": ["/^eslint/", "/^@typescript-eslint/", "/^prettier/", "/^pretty-quick/"],
      "groupName": "Linting and formatting"
    },
    {
      "matchUpdateTypes": ["patch"],
      "groupName": "Patch updates",
      "automerge": true,
      "automergeType": "pr"
    }
  ],
  "platformAutomerge": true
}
